# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Optional — offline fallback only. When set AND the Hub is unreachable,
# the bot falls back to this env-based whitelist (numeric TG user id).
# In normal operation the owner configures Settings → Telegram Bridge in
# the Hub UI, which is the authoritative source.
# WHITELIST_TG_USER_ID=

# Absolute path to the `claude` CLI binary.
# Find with: which claude
CC_BINARY_PATH=/opt/homebrew/bin/claude

# Working directory for CC invocations.
CC_WORKDIR=/Users/<you>/Documents/my_projects/my-personal-hub

# CC subprocess timeout in seconds.
CC_TIMEOUT=300

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Personal Hub backend base URL (no trailing slash required).
HUB_API_URL=https://backend-api-production-1967.up.railway.app

# API token minted via Settings → Integrations in the Hub UI. Starts with `phub_`.
HUB_API_TOKEN=phub_replace_me_mint_via_settings_ui

# faster-whisper voice transcription.
WHISPER_MODEL_SIZE=small
WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=cpu

# Optional comma-separated sibling project names hidden from /project.
PROJECT_DENY=
