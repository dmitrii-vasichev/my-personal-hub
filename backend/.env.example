# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/personal_hub

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# Admin seed
