# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/personal_hub

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ── Admin seed ─────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# ── Demo seed ─────────────────────────────────────────────────────────────────
DEMO_PASSWORD=demo2026

# ── Encryption (Fernet key for API keys at rest) ──────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Google Calendar OAuth2 ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/calendar/oauth/callback

# ── Telegram (Telethon MTProto client) ─────────────────────────────────────
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=

# ── Frontend URL (for OAuth redirects) ────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── CORS (comma-separated allowed origins) ────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development

# ── Frontend ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
